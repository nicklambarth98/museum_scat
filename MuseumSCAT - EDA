 \n---\nThis will focus on 5 things: \n1. Date Format Distribution - how often are roman numerals, partial dates or MISSING used?\n2. Locality Complexity Distribution - Simple place codes (e.g. \"Kb\") vs Full Heirarchical strings vs coordinates.\n3. Multicard Frequency - How often are outputs pipe separated?\n4. Label Condition - Display a small number of image samples, what state are they in? Checking legibility, fading, damage.\n5. Character Set - How often are Danish characters used?\n\nThese will inform the required pre-processing steps.","metadata":{}},{"cell_type":"code","source":"# ----- 1. Date Format Distribution -----\n# Classify date patterns\nROMAN_RE   = re.compile(r\"\\b(I{1,3}|IV|V?I{0,3}|IX|X{0,3}(?:IX|IV|V?I{0,3}))\\b\", re.IGNORECASE)\nCOORD_RE   = re.compile(r\"\\d+\\.\\d+[NS]\")\n\ndef classify_date(d):\n    if d == \"MISSING\" or pd.isna(d):\n        return \"MISSING\"\n    d = str(d)\n    if \"|\" in d:\n        return \"Multi-card\"\n    if ROMAN_RE.search(d):\n        return \"Roman numeral month\"\n    if re.match(r\"^\\d{1,2}[./ -]\\d{1,2}[./ -]\\d{2,4}$\", d.strip()):\n        return \"DD.MM.YYYY\"\n    if re.match(r\"^\\d{1,2}/\\d{4}$\", d.strip()):\n        return \"MM/YYYY\"\n    if re.match(r\"^\\d{1,2}[./ -]\\d{2,4}$\", d.strip()):\n        return \"Partial (D.YY)\"\n    if re.match(r\"^\\d{4}$\", d.strip()):\n        return \"Year only\"\n    if re.match(r\"^\\d{1,2}/\\d{2}$\", d.strip()):\n        return \"MM/YY\"\n    return \"Other\"\n\ntrain[\"date_pattern\"] = train[\"verbatimDate\"].apply(classify_date)\n\n# Punctuation style\ndef date_punct(d):\n    if d in (\"MISSING\",) or pd.isna(d):\n        return \"MISSING\"\n    d = str(d)\n    if \"/\" in d: return \"slash /\"\n    if \".\" in d: return \"dot .\"\n    if \"-\" in d: return \"dash -\"\n    if \" \" in d: return \"space\"\n    return \"other\"\n\ntrain[\"date_punct\"] = train[\"verbatimDate\"].apply(date_punct)\n\nfig, axes = plt.subplots(2, 1, figsize=(16, 16))\nfig.suptitle(\"Date Deep-Dive Analysis\", fontsize=16, fontweight=\"bold\")\n\n# Pattern distribution\npat_counts = train[\"date_pattern\"].value_counts()\naxes[0].barh(pat_counts.index, pat_counts.values, color = ['c', 'y', 'm'], edgecolor=\"white\")\naxes[0].set_title(\"Date Pattern Types\", fontweight=\"bold\")\naxes[0].set_xlabel(\"Count\")\nfor i, (idx, v) in enumerate(pat_counts.items()):\n    axes[0].text(v + 0.2, i, f\"{v} ({v/len(train)*100:.0f}%)\", va=\"center\")\n\n# Punctuation Style\npunct_counts = train[\"date_punct\"].value_counts()\naxes[1].bar(punct_counts.index, punct_counts.values, color = ['c', 'y', 'm', 'g', 'b', 'r'], edgecolor=\"white\")\naxes[1].set_title(\"Date Punctuation Style\", fontweight=\"bold\")\naxes[1].set_ylabel(\"Count\")\nfor i, v in enumerate(punct_counts.values):\n    axes[1].text(i, v + 0.2, str(v), ha=\"center\", fontweight=\"bold\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T11:28:15.089038Z","iopub.execute_input":"2026-06-18T11:28:15.089385Z","iopub.status.idle":"2026-06-18T11:28:15.563473Z","shell.execute_reply.started":"2026-06-18T11:28:15.089358Z","shell.execute_reply":"2026-06-18T11:28:15.562454Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x1600 with 2 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":18},{"cell_type":"markdown","source":"Roughly two thirds of the training set has roman numerals in the date. \n\nThere is a number of well represented date punctuation styles","metadata":{}},{"cell_type":"code","source":"# ----- 2. LOCALITY  COMPLEXITY DISTRIBUTION -----\ndef classify_locality(loc: str) -> str:\n    \"\"\"Bucket a locality string into a complexity tier.\"\"\"\n    if pd.isna(loc) or str(loc).upper() == 'NULL':\n        return 'NULL'\n    loc = str(loc)\n    has_coords   = bool(re.search(r'\\d+\\.\\d+[NS]', loc))\n    has_pipe     = '|' in loc\n    word_count   = len(loc.split())\n    has_hierarch = ',' in loc or ':' in loc\n\n    if has_coords:\n        return 'Coordinates'\n    elif has_pipe:\n        return 'Multi-card'\n    elif has_hierarch or word_count >= 4:\n        return 'Hierarchical'\n    elif word_count <= 2:\n        return 'Simple code/name'\n    else:\n        return 'Medium'\n\ntrain['loc_complexity'] = train['verbatimLocality'].apply(classify_locality)\n\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\n\n# Count plot\norder = train['loc_complexity'].value_counts().index\nsns.countplot(data=train, y='loc_complexity', order=order, ax=axes[0], palette='viridis')\naxes[0].set_title('Locality Complexity Tiers')\naxes[0].set_xlabel('Count')\naxes[0].set_ylabel('')\n\n# Character length distribution per tier\ntrain['loc_len'] = train['verbatimLocality'].apply(\n    lambda x: len(str(x)) if str(x).upper() != 'NULL' else 0\n)\nfor tier in order:\n    subset = train[train['loc_complexity'] == tier]['loc_len']\n    axes[1].hist(subset, bins=20, alpha=0.6, label=tier)\naxes[1].set_title('Locality String Length by Tier')\naxes[1].set_xlabel('Character length')\naxes[1].legend(fontsize=8)\n\nplt.tight_layout()\nplt.show()\n\nprint(train['loc_complexity'].value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T11:28:15.564925Z","iopub.execute_input":"2026-06-18T11:28:15.565289Z","iopub.status.idle":"2026-06-18T11:28:16.093725Z","shell.execute_reply.started":"2026-06-18T11:28:15.565258Z","shell.execute_reply":"2026-06-18T11:28:16.092908Z"}},"outputs":[{"name":"stderr","text":"/tmp/ipykernel_58/3095824602.py:29: FutureWarning: \n\nPassing `palette` without assigning `hue` is deprecated and will be removed in v0.14.0. Assign the `y` variable to `hue` and set `legend=False` for the same effect.\n\n  sns.countplot(data=train, y='loc_complexity', order=order, ax=axes[0], palette='viridis')\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1300x400 with 2 Axes>","image/png":"\n"},"metadata":{